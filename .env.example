# ══════════════════════════════════════════════════════════════
#  YellowKode Chat — Configuração / Configuration
#
#  COMO USAR / HOW TO USE:
#    cp .env.example .env
#    docker compose up -d
#    Acesse / Open: http://localhost:3000
# ══════════════════════════════════════════════════════════════

# ── Modelo de IA / AI Model ────────────────────────────────────
# Escolha conforme sua RAM disponível:
# Choose based on your available RAM:
#
#   gemma4:e2b  → ~1 GB   (mínimo — 4 GB RAM, CPU)
#   gemma4:e4b  → ~2.5 GB (recomendado ✅ — 8 GB RAM)
#   gemma4:12b  → ~7 GB   (alta qualidade — 8 GB+ RAM)
#   gemma4:26b  → ~15 GB  (melhor qualidade — GPU recomendada)
GEMMA_MODEL=gemma4:e4b

# ── Banco de dados / Database ──────────────────────────────────
# Senha do PostgreSQL — pode manter o padrão em desenvolvimento
# PostgreSQL password — default is fine for local use
DB_PASSWORD=yk_chat_local

# ── Portas / Ports ─────────────────────────────────────────────
# Interface principal do chat / Main chat interface
UI_PORT=3000
# Open WebUI (interface alternativa opcional / optional alternative UI)
WEBUI_PORT=8080
# Porta externa do Ollama / Ollama external port
# Mude para 11435 se rodar yk-agent ao mesmo tempo / Change to 11435 if running yk-agent simultaneously
OLLAMA_PORT=11434

# ── Open WebUI ─────────────────────────────────────────────────
# Troque em produção / Change in production
WEBUI_SECRET_KEY=change-me-in-production

# ── Produção com Traefik / Production with Traefik ─────────────
# Apenas para deploy com domínio próprio / Only for VPS deployment
DOMAIN=yourdomain.com
